# Telegram Bot
BOT_TOKEN=7000000000:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WEBAPP_URL=https://your-domain.com

# Backend
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/tibbiyot_novatorlari
SYNC_DATABASE_URL=postgresql://postgres:password@localhost:5432/tibbiyot_novatorlari

# Redis
REDIS_URL=redis://localhost:6379/0

# S3 Storage
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=tibbiyot-files
S3_REGION=us-east-1

# Email
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-sendgrid-api-key
FROM_EMAIL=noreply@tibbiyotnovatorlari.uz

# App
DEBUG=False
ALLOWED_ORIGINS=https://your-domain.com,https://t.me
API_PREFIX=/api/v1
